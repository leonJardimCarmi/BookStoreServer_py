from flask import Flask ,make_response, request ,jsonify

app = Flask(__name__)

books_db={ }
next_book_id=1
ALL_GENRES ={"SCI_FI", "NOVEL", "HISTORY", "MANGA", "ROMANCE", "PROFESSIONAL"}

@app.route('/books/health', methods= ['GET'])
def health_check():
    response = make_response("OK" , 200)
    response.mimetype= "text/plain"
    return response

@app.route('/book', methods= ['POST'])
def create_book():
    global next_book_id
    data = request.get_json()

    title = data.get('title')
    author = data.get('author')
    year = data.get('year')
    price = data.get('price')
    genres = data.get('genres')

    if price <= 0:
        return (jsonify({"errorMessage":"Error: Can’t create new Book with negative price" }) ,
                409)
    if year <1940 or year > 2100:
        return jsonify({
            "errorMessage": f"Error: Can’t create new Book that its year [{year}] is not in the accepted range [1940 -> 2100]"
        }), 409
    for existing_book in books_db.values():
        if existing_book['title'].lower() == title.lower():
            return jsonify({
                "errorMessage": f"Error: Book with the title [{title}] already exists in the system"
            }), 409

    assigned_id = next_book_id
    new_book = {
        "id": assigned_id,
        "title": title,
        "author": author,
        "year": year,
        "price": price,
        "genres": genres
    }
    books_db[assigned_id] = new_book
    next_book_id +=1

    return jsonify({"result": assigned_id}), 200

def get_filtered_books():
    author_filter = request.args.get('author')
    price_bigger_filter = request.args.get('price-bigger-than')
    price_less_filter = request.args.get('price-less-than')
    year_bigger_filter = request.args.get('year-bigger-than')
    year_less_filter = request.args.get('year-less-than')
    genres_filter = request.args.get('genres')

    try:
        if price_bigger_filter is not None:
            price_bigger_filter = int(price_bigger_filter)
        if price_less_filter is not None:
            price_less_filter = int(price_less_filter)
        if year_bigger_filter is not None:
            year_bigger_filter = int(year_bigger_filter)
        if year_less_filter is not None:
            year_less_filter = int(year_less_filter)
    except ValueError:
        return "NUMERIC_ERROR"

    filtered_books = list(books_db.values())

    if author_filter is not None:
        filtered_books = [b for b in filtered_books if b['author'].lower() == author_filter.lower()]
    if price_bigger_filter is not None:
        filtered_books = [b for b in filtered_books if b['price'] >= price_bigger_filter]
    if price_less_filter is not None:
        filtered_books = [b for b in filtered_books if b['price'] <= price_less_filter]
    if year_bigger_filter is not None:
        filtered_books = [b for b in filtered_books if b['year'] >= year_bigger_filter]
    if year_less_filter is not None:
        filtered_books = [b for b in filtered_books if b['year'] <= year_less_filter]
    if genres_filter is not None:
        requested_genres = genres_filter.split(',')
        for g in requested_genres:
            if g not in ALL_GENRES:
                return "GENRES_ERROR"
        filtered_books = [
            b for b in filtered_books
            if len(set(b['genres']).intersection(set(requested_genres))) > 0
        ]

    return  filtered_books

@app.route('/books/total', methods= ['GET'])
def get_total_books():
    filtered_books = get_filtered_books()

    if filtered_books == "NUMERIC_ERROR":
        return jsonify({"errorMessage": "Error: Invalid numeric parameter"}), 400
    if filtered_books == "GENRES_ERROR":
        return jsonify({"errorMessage": "Error: Invalid genre parameter"}), 400

    return jsonify({"result": len(filtered_books)}), 200

@app.route('/books', methods= ['GET'])
def get_books_data():
    filtered_books = get_filtered_books()

    if filtered_books == "NUMERIC_ERROR":
        return jsonify({"errorMessage": "Error: Invalid numeric parameter"}), 400
    if filtered_books == "GENRES_ERROR":
        return jsonify({"errorMessage": "Error: Invalid genre parameter"}), 400

    sorted_books = sorted(filtered_books, key=lambda book: book['title'].lower())

    return jsonify({"result": sorted_books}), 200

@app.route('/book', methods= ['GET'])
def single_book_data():
    book_id= request.args.get('id')
    try :
        book_id = int(book_id)
    except (ValueError, TypeError):
        return jsonify({"errorMessage": f"Error: no such Book with id {str(book_id)}"}), 404

    if book_id in books_db:
        return jsonify({"result": books_db[book_id]}), 200

    return jsonify({"errorMessage": f"Error: no such Book with id {book_id}"}), 404

@app.route('/book', methods= ['PUT'])
def update_book_price():
    book_id_raw= request.args.get('id')
    new_book_price_raw = request.args.get('price')
    try :
        book_id = int(book_id_raw)
        new_book_price = int(new_book_price_raw)
    except (ValueError, TypeError):
        return jsonify({"errorMessage": f"Error: no such Book with id {book_id_raw}"
                        }), 404

    if book_id not in books_db:
        return (jsonify({"errorMessage": f"Error: no such Book with id {book_id}"
                         }),404)

    if new_book_price <= 0:
        return jsonify({
            "errorMessage": f"Error: price update for Book [{book_id}] must be a positive integer"
                         }), 409

    old_price = books_db[book_id]['price']
    books_db[book_id]['price'] = new_book_price

    return jsonify({"result": old_price}), 200

@app.route('/book', methods= ['DELETE'])
def delete_book():
    book_id_raw= request.args.get('id')
    try :
        book_id = int(book_id_raw)
    except (ValueError, TypeError):
        return jsonify({"errorMessage": f"Error: no such book with id {book_id_raw}"}),404

    if book_id not in books_db:
        return jsonify({"errorMessage": f"Error: no such book with id {book_id}"}), 404

    del books_db[book_id]

    return jsonify({"result": len(books_db)}), 200


if __name__ == '__main__':
    app.run(host= '0.0.0.0', port=8574, threaded=False, debug=False)



